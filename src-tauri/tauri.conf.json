{
  "productName": "AMT Client",
  "version": "0.1.0",
  "identifier": "com.amt.client",
  "build": {
    "beforeBuildCommand": "bun run build",
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AMT Client",
        "label": "main",
        "width": 1100,
        "minWidth": 1000,
        "height": 720,
        "minHeight": 670,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "center": true,
        "windowEffects": {
          "effects": [
            "acrylic"
          ]
        },
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "Game",
    "copyright": "AMT Client",
    "publisher": "AMT",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AMT Client - A performance-focused Minecraft Launcher",
    "longDescription": "AMT Client is a performance-focused, legitimate Minecraft Launcher and Client with deep customizability, cosmetics ecosystem, and in-game HUD system.",
    "license": "GPL-3.0",
    "licenseFile": "../LICENSE",
    "resources": [],
    "targets": "all",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "currentUser"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "rpm": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  }
}
